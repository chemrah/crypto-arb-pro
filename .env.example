# ═══════════════════════════════════════════════════
# Crypto Arbitrage Pro - Environment Variables
# ═══════════════════════════════════════════════════

# RPC URLs (مجاني من Alchemy أو Infura)
NEXT_PUBLIC_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Testnet RPCs
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Chain ID
NEXT_PUBLIC_CHAIN_ID=42161

# المحفظة (لا تشارك هذا أبداً!)
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Biconomy Paymaster (مجاني - سجل في dashboard.biconomy.io)
BICONOMY_API_KEY=your_biconomy_api_key
BICONOMY_PAYMASTER_URL=https://paymaster.biconomy.io/api/v1/42161/YOUR_KEY
BUNDLER_URL=https://bundler.biconomy.io/

# Flashbots (حماية MEV)
FLASHBOTS_RELAY=https://relay.flashbots.net

# Server
PORT=3001
WS_PORT=3002

# العقود المنشورة
ARB_CONTRACT_ADDRESS=0x...
FLASH_LOAN_CONTRACT=0x...
FLASH_MINT_CONTRACT=0x...

# Etherscan API (للتحقق من العقود)
ARBISCAN_API_KEY=your_arbiscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
