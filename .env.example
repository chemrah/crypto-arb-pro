# ═══════════════════════════════════════════════════════════
# Crypto Arbitrage Pro v2.0 — Environment Variables
# ═══════════════════════════════════════════════════════════

# ──────────── RPC Providers (Alchemy + Infura) ────────────
# Get free keys: https://www.alchemy.com / https://infura.io
ALCHEMY_API_KEY=your_alchemy_api_key_here
INFURA_API_KEY=your_infura_api_key_here

# Direct RPC URLs (fallback if no API keys)
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# WebSocket URLs
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Testnet RPCs
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ──────────── Network Mode ────────────
# Options: mainnet | testnet
NETWORK_MODE=testnet
NEXT_PUBLIC_CHAIN_ID=42161

# ──────────── Wallet (NEVER share or commit!) ────────────
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# ──────────── Biconomy Paymaster (Gasless) ────────────
# Register at: https://dashboard.biconomy.io
# Create a Paymaster on Arbitrum (chain 42161)
# Whitelist your deployed contract addresses
# Fund the Paymaster with gas credits
BICONOMY_API_KEY=your_biconomy_api_key
BICONOMY_PAYMASTER_URL=https://paymaster.biconomy.io/api/v1/42161/YOUR_KEY
BUNDLER_URL=https://bundler.biconomy.io/api/v2/42161/YOUR_KEY

# ──────────── Flashbots (MEV Protection) ────────────
FLASHBOTS_RELAY=https://relay.flashbots.net

# ──────────── Execution Config ────────────
# Auto-execute mode: automatically execute profitable opportunities
AUTO_EXECUTE=false
# Minimum profit threshold in USD (detects all arbs >= this amount)
MIN_PROFIT_USD=1
# Maximum gas price to pay (in gwei) — safety limit
MAX_GAS_PRICE_GWEI=0.5
# Slippage tolerance (0.005 = 0.5%)
SLIPPAGE_TOLERANCE=0.005

# ──────────── Server ────────────
PORT=3001

# ──────────── Deployed Contracts ────────────
# Deploy with: npx hardhat run scripts/deploy.js --network arbitrumSepolia
FLASH_LOAN_CONTRACT=0x...
FLASH_SWAP_CONTRACT=0x...
FLASH_MINT_CONTRACT=0x...
MULTI_HOP_ROUTER=0x...

# ──────────── Block Explorer APIs ────────────
ARBISCAN_API_KEY=your_arbiscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
