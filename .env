BASE_RPC=https://base-mainnet.g.alchemy.com/v2/fImvqTZuIJ1kuBBI-jN__
ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/fImvqTZuIJ1kuBBI-jN__

# WebSocket URLs
