BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/fImvqTZuIJ1kuBBI-jN__

# ──────────── Network Mode ────────────
# Options: mainnet | testnet
NETWORK_MODE=testnet
NEXT_PUBLIC_CHAIN_ID=42161

# ──────────── Wallet (NEVER share or commit!) ────────────
PRIVATE_KEY=e3c7142fb69af9754327b42aa34dafe7b5770f168e65b8dcd6968581d6437ed9
WALLET_ADDRESS=0x37026E198F3918E7be3192379c61FF98e8750F59

# ──────────── Biconomy Paymaster (Gasless) ────────────
# Register at: https://dashboard.biconomy.io
# Create a Paymaster on Arbitrum (chain 42161)
# Whitelist your deployed contract addresses
# Fund the Paymaster with gas credits
BICONOMY_API_KEY=mee_MJVSAfsKKhvioiLsEknRXb
BICONOMY_PAYMASTER_URL=https://paymaster.biconomy.io/api/v1/42161/mee_MJVSAfsKKhvioiLsEknRXb
BUNDLER_URL=https://bundler.biconomy.io/api/v2/42161/mee_MJVSAfsKKhvioiLsEknRXb

# ──────────── Flashbots (MEV Protection) ────────────
FLASHBOTS_RELAY=https://relay.flashbots.net

# ──────────── Execution Config ────────────
# Auto-execute mode: automatically execute profitable opportunities
AUTO_EXECUTE=false
# Minimum profit threshold in USD (detects all arbs >= this amount)
MIN_PROFIT_USD=1
# Maximum gas price to pay (in gwei) — safety limit
MAX_GAS_PRICE_GWEI=0.5
# Slippage tolerance (0.005 = 0.5%)
SLIPPAGE_TOLERANCE=0.005

# ──────────── Server ────────────
PORT=3001

# ──────────── Deployed Contracts ────────────
# Deploy with: npx hardhat run scripts/deploy.js --network arbitrumSepolia
FLASH_LOAN_CONTRACT=0x...
FLASH_SWAP_CONTRACT=0x...
FLASH_MINT_CONTRACT=0x...
MULTI_HOP_ROUTER=0x...

# ──────────── Block Explorer APIs ────────────
ARBISCAN_API_KEY=your_arbiscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
